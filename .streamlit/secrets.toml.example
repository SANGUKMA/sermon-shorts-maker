# Streamlit Secrets 템플릿
# 실제 사용할 때는 이 파일을 secrets.toml로 복사하고 값을 채워넣으세요.
# secrets.toml은 .gitignore에 등록되어 있어 커밋되지 않습니다.

# Streamlit Cloud 배포 시:
#   App settings → Secrets 탭에 직접 붙여넣기 (이 파일의 내용 그대로)

# ─── ElevenLabs (TTS) ────────────────────────────────────────────────
ELEVENLABS_API_KEY = "sk_..."
# 사용자(목사님) 본인 음성 클론의 voice_id
# Professor ma (W9zbcgJ4rDpkhoG8WtRU)는 자매 repo 본인 음성이라 사용 금지
ELEVENLABS_VOICE_ID = "your_voice_id_here"

# ─── Google Imagen 4 (이미지 생성) ────────────────────────────────────
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY = "AIza..."

# ─── Kling AI (I2V 영상) ─────────────────────────────────────────────
# https://app.klingai.com/global/dev/ 에서 발급
# 주의: 웹 크레딧과 API 리소스 팩은 별개. API 리소스 팩 별도 구매 필요.
KLING_ACCESS_KEY = "..."
KLING_SECRET_KEY = "..."

# ─── Anthropic Claude (메타데이터 생성) ──────────────────────────────
ANTHROPIC_API_KEY = "sk-ant-..."

# ─── 앱 설정 (필수 아님) ────────────────────────────────────────────
[app]
default_church_name = "예수믿는교회"
default_pastor_name = "마상욱 목사"
